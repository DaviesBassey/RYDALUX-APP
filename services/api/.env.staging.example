# ── RYDALUX Staging API Environment Configuration ──
NODE_ENV=staging
PORT=4000
LOG_LEVEL=info

# PostgreSQL database URL (Staging DB, Postgres + PostGIS)
DATABASE_URL=postgresql://staging_user:replace_with_secure_staging_password@staging-db-host:5432/rydalux_staging?schema=public

# Redis caching and job queue URL
REDIS_URL=redis://staging-redis-host:6379

# Cryptography & JWT Secrets (Min 32 characters, generate with 'openssl rand -base64 48')
JWT_ACCESS_SECRET=replace-with-secure-random-string-min-32-chars-staging
JWT_REFRESH_SECRET=replace-with-secure-random-string-min-32-chars-staging

# CORS Origins (Comma-separated origins, no wildcards)
# Example: https://admin-staging.rydalux.com,https://app-staging.rydalux.com
CORS_ORIGIN=https://admin-staging.rydalux.com

# Paystack Test Gateway configuration
PAYSTACK_SECRET_KEY=sk_test_replace_with_paystack_test_secret_key
PAYSTACK_WEBHOOK_SECRET=replace_with_paystack_webhook_secret_for_staging
PAYSTACK_CALLBACK_URL=https://api-staging.rydalux.com/payments/paystack/callback

# SMS/OTP Provider Configuration
# Set to 'africastalking' or 'none' (none will mock and print OTPs to log)
SMS_PROVIDER=none
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=replace_with_africastalking_test_key
AFRICASTALKING_SENDER_ID=RYDALUX

# Administrative initial setup
ADMIN_EMAIL=admin@rydalux.local
ADMIN_PASSWORD=LocalAdminPass123!

# Financial scheduler config (disabled = true/false)
FINANCE_SCHEDULER_DISABLED=false
