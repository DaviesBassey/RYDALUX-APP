{
  "name": "@rydulux/api-services-local",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "nest start --watch",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "test": "jest",
    "test:integration": "jest --config jest-integration.json",
    "test:e2e": "jest --config jest-e2e.json",
    "test:all": "jest && npm run test:integration && npm run test:e2e",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "outbox:process": "OUTBOX_SCHEDULER_DISABLED=true ts-node src/outbox/process-outbox.ts",
    "seed:admin": "ts-node prisma/seed.ts",
    "seed:staging": "ts-node prisma/seed-staging.ts",
    "seed:ops:staging": "ts-node prisma/seed-operations-staging.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/throttler": "^3.0.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.13.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.3.2",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@jest/types": "^30.4.1",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.19",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.12",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.13.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.2"
  }
