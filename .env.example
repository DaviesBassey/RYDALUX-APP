# ── RYDALUX Environment Configuration ──
# Copy this file to .env and fill in all required values.
# Never commit .env files — they contain secrets.

# ── Node / App ──
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ── Database ──
# Required by docker-compose.prod.yml for the production Postgres container.
POSTGRES_PASSWORD=replace-with-secure-postgres-password
# PostgreSQL + PostGIS connection string
DATABASE_URL=postgresql://rydalux:rydaluxpass@localhost:5432/rydalux

# ── Cache / Queue ──
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (min 32 characters each) ──
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-secure-random-string-min-32-chars

# ── CORS ──
# Comma-separated list of allowed origins. No wildcards in production.
# Example: https://admin.rydalux.com,https://app.rydalux.com
CORS_ORIGIN=

# ── Payment Providers ──
# Required in production. Use real provider secrets only in local .env / deployment secrets.
PAYSTACK_SECRET_KEY=replace-with-paystack-secret-key
PAYSTACK_WEBHOOK_SECRET=replace-with-paystack-webhook-secret
PAYSTACK_CALLBACK_URL=
FLUTTERWAVE_SECRET_KEY=

# ── SMS / OTP ──
# Provider: 'africastalking' or 'none'
# 'none' will cause OTP requests to fail in production.
SMS_PROVIDER=none
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=RYDALUX

# ── First Super Admin ──
# Set these before running `pnpm seed:admin` to create the initial admin user.
# Password must be at least 12 characters.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Scheduler ──
# Set to 'true' to disable the finance reconciliation scheduler
FINANCE_SCHEDULER_DISABLED=false

# ── Admin / API URLs (for local development) ──
NEXTAUTH_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Local Production Verification ──
# Required for `docker compose -f docker-compose.prod.yml up -d`.
# Use safe local-only values for verification; do not commit real secrets.
# POSTGRES_PASSWORD=replace-with-secure-postgres-password
# DATABASE_URL=postgresql://rydalux:${POSTGRES_PASSWORD}@postgres:5432/rydalux
# REDIS_URL=redis://redis:6379
# JWT_ACCESS_SECRET=replace-with-secure-random-string-min-32-chars
# JWT_REFRESH_SECRET=replace-with-secure-random-string-min-32-chars
# CORS_ORIGIN=http://localhost:3000
# PAYSTACK_SECRET_KEY=replace-with-paystack-secret-key
# PAYSTACK_WEBHOOK_SECRET=replace-with-paystack-webhook-secret

# ── Deprecated / Unused ──
# The following are reserved for future features and are not currently used:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
