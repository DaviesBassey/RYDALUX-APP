# ── RYDALUX Environment Configuration ──
# Copy this file to .env and fill in all required values.
# Never commit .env files — they contain secrets.

# ── Node / App ──
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ── Database ──
# PostgreSQL + PostGIS connection string
DATABASE_URL=postgresql://rydalux:rydaluxpass@localhost:5432/rydalux

# ── Cache / Queue ──
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (min 32 characters each) ──
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-secure-random-string-min-32-chars

# ── CORS ──
# Comma-separated list of allowed origins. No wildcards in production.
# Example: https://admin.rydalux.com,https://app.rydalux.com
CORS_ORIGIN=

# ── Payment Providers ──
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=
FLUTTERWAVE_SECRET_KEY=

# ── SMS / OTP ──
# Provider: 'africastalking' or 'none'
# 'none' will cause OTP requests to fail in production.
SMS_PROVIDER=none
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=RYDALUX

# ── First Super Admin ──
# Set these before running `pnpm seed:admin` to create the initial admin user.
# Password must be at least 12 characters.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Scheduler ──
# Set to 'true' to disable the finance reconciliation scheduler
FINANCE_SCHEDULER_DISABLED=false

# ── Admin / API URLs (for local development) ──
NEXTAUTH_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Deprecated / Unused ──
# The following are reserved for future features and are not currently used:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
